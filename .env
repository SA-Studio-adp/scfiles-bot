# ──────────────────────────────────────────────
# SCFiles Backend Manager Bot — Environment Variables
# Copy this to .env and fill in your values
# ──────────────────────────────────────────────

# Your Telegram Bot Token (from @BotFather)
TELEGRAM_TOKEN=YOUR_BOT_TOKEN_HERE

# Your SCFiles backend URL (e.g. https://scfiles-backend.vercel.app)
BACKEND_URL=https://your-backend-url.vercel.app

# TMDB API Key (from https://www.themoviedb.org/settings/api)
TMDB_API_KEY=YOUR_TMDB_API_KEY_HERE

# Comma-separated Telegram user IDs allowed to use admin commands
# Leave empty to allow everyone (not recommended)
ADMIN_IDS=123456789,987654321

# Telegram chat/channel ID where backups will be sent
# Use your own chat ID, or a private channel ID (e.g. -100xxxxxxxxxx)
BACKUP_CHAT_ID=YOUR_CHAT_ID_HERE
