# ──────────────────────────────────────────────
# SCFiles Backend Manager Bot (Pyrogram Edition)
# ──────────────────────────────────────────────

# ── Pyrogram credentials (required!) ──────────
# Get API_ID and API_HASH from https://my.telegram.org/apps
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# Your Telegram Bot Token (from @BotFather)
TELEGRAM_TOKEN=YOUR_BOT_TOKEN_HERE

# ── Backend ───────────────────────────────────
# Your SCFiles backend URL
BACKEND_URL=https://your-backend-url.vercel.app

# ── TMDB ─────────────────────────────────────
# API key from https://www.themoviedb.org/settings/api
TMDB_API_KEY=YOUR_TMDB_API_KEY_HERE

# ── Access control ────────────────────────────
# Comma-separated Telegram user IDs for admin-only commands
# Leave empty to allow everyone (NOT recommended)
ADMIN_IDS=123456789,987654321

# ── Backup ────────────────────────────────────
# Chat/channel ID to receive auto-backups
# Your own chat ID, or a private channel like -100xxxxxxxxxx
BACKUP_CHAT_ID=YOUR_CHAT_ID_HERE

# ── Web Dashboard ─────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=8080
# Public URL of this bot's web dashboard (optional, shown in /start menu)
BOT_WEB_URL=https://your-bot.example.com

# ── Auto-ping interval (minutes) ─────────────
AUTO_PING_INTERVAL_MIN=5
